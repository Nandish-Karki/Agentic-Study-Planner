# Secrets — never commit
.env
.env.*
!.env.example
*.key
*.pem

# Personal documents — CV, transcript, etc. NEVER commit
data/*.pdf
data/*.docx

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/
dist/
build/

# Outputs (regenerated each run)
outputs/

# Local databases (dev SQLite; prod uses Postgres)
*.db
*.sqlite
*.sqlite3

# Demo event log — contains volunteered emails + feedback, never commit
demo/events.jsonl

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
