# Secrets — never commit
.env
.env.*
!.env.example
*.key
*.pem

# Personal documents — CV, transcript, etc. NEVER commit
data/*.pdf
data/*.docx

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/
dist/
build/

# Outputs (regenerated each run)
outputs/

# Local databases (dev SQLite; prod uses Postgres)
*.db
*.sqlite
*.sqlite3

# Demo event log — contains volunteered emails + feedback, never commit
demo/events.jsonl

# Frontend (Vite/React)
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/*.local
# TS incremental build cache + files emitted from vite.config.ts by tsc -b
*.tsbuildinfo
frontend/vite.config.js
frontend/vite.config.d.ts

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db
