# Copy this file to .env and fill in your real keys. NEVER commit .env.

# === LLM provider selection ===
# "github" → GitHub Models (needs GITHUB_TOKEN with models:read permission)
# "groq"   → Groq free tier (needs GROQ_API_KEY; 12k tokens/request, 100k/day)
LLM_PROVIDER=github

# Optional model overrides (defaults shown)
# LLM_MODEL_FAST=github/gpt-4o-mini
# LLM_MODEL_SMART=github/gpt-4o

# === API keys ===
GITHUB_TOKEN=github_pat_YOUR_TOKEN_HERE
GROQ_API_KEY=gsk_YOUR_KEY_HERE

# === Production API (study_planner.api) — BUILD_PLAN B3-B5 ===
# Auth: REQUIRED in any real deployment (DEBUG=0). Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=
DEBUG=1
ACCESS_TOKEN_TTL_MIN=60

# Database — SQLite for dev (default below); Postgres in prod (EU region):
#   DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/study_planner
DATABASE_URL=sqlite+aiosqlite:///./study_planner.db

# Jobs — "eager" runs the crew inline (dev); "rq" uses Redis + a worker (prod).
JOB_MODE=eager
REDIS_URL=redis://localhost:6379/0

# Guardrails
MAX_PLANS_PER_DAY=5
AUTH_RATE_LIMIT=10
AUTH_RATE_WINDOW_S=300
# When the shared free-tier LLM quota is exhausted, pause plans for this many hours
# and show users a "come back later" message (instead of failing jobs).
QUOTA_COOLDOWN_HOURS=24

# === Email (verification + password reset) ===
# PREFERRED on hosts that block outbound SMTP (Render free tier makes
# smtp.gmail.com:587 unreachable -> "[Errno 101] Network is unreachable"): use the
# Resend HTTP API. When RESEND_API_KEY is set, mail goes over HTTPS and the SMTP_*
# vars are ignored. Get a key at https://resend.com (free 3k/month). SMTP_FROM must
# be a Resend-verified sender/domain (use onboarding@resend.dev to test to yourself).
#   RESEND_API_KEY=re_xxxxxxxx
#   SMTP_FROM=Study Planner <onboarding@resend.dev>
RESEND_API_KEY=
#
# Local dev: Mailpit catches everything — host=mailpit, port=1025, no auth/TLS,
# read it at http://localhost:8025 (this is what docker-compose wires).
# PROD: point at a real provider. Leave SMTP_HOST blank to disable email (links are
# then only logged / returned when DEBUG=1) — NOT viable for a public launch.
# Examples:
#   Resend:    SMTP_HOST=smtp.resend.com  SMTP_PORT=465 SMTP_SSL=1   SMTP_USER=resend       SMTP_PASSWORD=re_...
#   SendGrid:  SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587 SMTP_STARTTLS=1 SMTP_USER=apikey   SMTP_PASSWORD=SG....
#   AWS SES:   SMTP_HOST=email-smtp.<region>.amazonaws.com SMTP_PORT=587 SMTP_STARTTLS=1 SMTP_USER=... SMTP_PASSWORD=...
#
# Gmail (quickest to ship; ~500 mails/day, weaker deliverability — fine for a demo):
#   1. Enable 2-Step Verification on the Google account.
#   2. Google Account -> Security -> App passwords -> generate one (16 chars, no spaces).
#   3. Use that App Password below (NOT your normal Gmail login password):
#        SMTP_HOST=smtp.gmail.com
#        SMTP_PORT=587
#        SMTP_USER=youraddress@gmail.com
#        SMTP_PASSWORD=xxxxxxxxxxxxxxxx        # the 16-char App Password
#        SMTP_STARTTLS=1
#        SMTP_SSL=0
#        SMTP_FROM=Study Planner <youraddress@gmail.com>   # From must match SMTP_USER
#        APP_BASE_URL=https://your-app.vercel.app          # so verify links open the frontend
#   (Alternatively use port 465 with SMTP_SSL=1 and SMTP_STARTTLS=0.)
# Use SMTP_SSL=1 for implicit TLS (port 465) OR SMTP_STARTTLS=1 for STARTTLS (587) — not both.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=1
SMTP_SSL=0
SMTP_FROM=Study Planner <no-reply@yourdomain.com>
# Used to build the verify/reset links in emails — set to your public frontend URL.
APP_BASE_URL=http://localhost:5173

# Frontend origin(s) for CORS in prod (comma-separated), e.g. https://app.example.com
ALLOWED_ORIGINS=*

# Optional: Google OAuth (leave blank to disable the /auth/oauth/google route)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
